ARG HERMES_BASE_IMAGE=nousresearch/hermes-agent:main
FROM ${HERMES_BASE_IMAGE}
ARG HERMES_BASE_IMAGE

WORKDIR /opt/career-steward-agent

LABEL org.opencontainers.image.title="Career Steward Agent" \
      org.opencontainers.image.description="Declarative career-steward agent reference implementation." \
      dev.selamy.base-image="${HERMES_BASE_IMAGE}" \
      dev.selamy.agent.manifest="/etc/career-steward/agent.manifest.yaml"

ENV PYTHONPATH="/opt/career-steward-agent/src"

COPY agent.manifest.yaml /etc/career-steward/agent.manifest.yaml
COPY contracts /etc/career-steward/contracts
COPY policies /etc/career-steward/policies
COPY skills /etc/career-steward/skills
COPY workflows /etc/career-steward/workflows
COPY schemas /etc/career-steward/schemas
COPY docs /opt/career-steward-agent/docs
COPY src/career_steward /opt/career-steward-agent/src/career_steward
COPY scripts /opt/career-steward-agent/scripts
COPY examples /opt/career-steward-agent/examples

ENTRYPOINT ["python3", "-m", "career_steward.sim"]
CMD ["--manifest", "/etc/career-steward/agent.manifest.yaml", "--input", "/opt/career-steward-agent/examples/sim/inbound-message.json", "--out", "/opt/data/sim-run.json"]
